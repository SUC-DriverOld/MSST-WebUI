# AMD GPU arch overrides (uncomment according your gpu)

# for RX 7000 Series (RDNA3)
#HSA_OVERRIDE_GFX_VERSION=11.0.0
#PYTORCH_ROCM_ARCH=gfx1100

# for RX 6000 Series (RDNA2)
#HSA_OVERRIDE_GFX_VERSION=10.3.0
#PYTORCH_ROCM_ARCH=gfx1030

# rocm paths in Fedora
LD_LIBRARY_PATH=./.venv/lib/python3.10/site-packages/torchaudio/lib:./.venv/lib/python3.10/site-packages/torch/lib:/usr/lib64:/usr/lib64/rocm

# Performance options (lower if needed)
PYTORCH_ALLOC_CONF=max_split_size_mb:512
